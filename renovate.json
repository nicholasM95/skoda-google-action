{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "assignees": [
    "nicholasM95"
  ],
  "baseBranchPatterns": [
    "develop"
  ],
  "packageRules": [
    {
      "matchFileNames": [
        ".github/workflows/**"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchFileNames": [
        "terraform/**"
      ],
      "automerge": true,
      "automergeType": "pr"
    }
  ]
}
